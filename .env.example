CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backhaul
AWS_REGION=us-east-1
S3_BUCKET_NAME=backhaul-ratecons
SQS_PARSE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/backhaul-parse
SQS_RECOMPUTE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/backhaul-recompute
# Optional LLM bootstrap fallback. The active provider/model/key are normally
# managed at runtime via the ADMIN Settings screen and stored (encrypted) in the
# LlmProviderConfig table. These are only used when no DB config row exists.
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
# Required to use the Settings-managed API key: 32-byte base64 key used to
# encrypt secrets at rest. Generate with: openssl rand -base64 32
CONFIG_ENCRYPTION_KEY=
PHASE1_REGION_CODE=NE
# Optional road-mileage routing for the copilot's create_load (loaded-mile auto-calc).
# Provider-agnostic; "google" uses the Google Distance Matrix API. Without a key the
# copilot falls back to asking for miles manually.
DISTANCE_PROVIDER=google
GOOGLE_MAPS_API_KEY=
